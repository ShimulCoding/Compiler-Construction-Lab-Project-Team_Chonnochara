int a = 8;
int b = 2;
bool yes = true;
bool no = false;

int add = a + b;
int subtract = a - b;
int multiply = a * b;
int divide = a / b;
int remainder = a % b;
float promoted = a + 2.5;

bool less = a < b;
bool greater = a > b;
bool less_equal = a <= b;
bool greater_equal = a >= b;
bool equal = a == b;
bool not_equal = a != b;
bool both = yes && no;
bool either = yes || no;
bool inverted = !yes;

print add;
print inverted;
